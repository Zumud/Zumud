# Zumud frontend environment — copy to `.env` (dev) or `.env.production`.
# Only NEXT_PUBLIC_* values reach the browser; never put secrets here.

# Backend API URL.
#  - Server-side / build: API_URL (defaults to http://localhost:8000)
#  - Browser: NEXT_PUBLIC_API_URL (e.g. https://api.your-domain.com in prod)
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# PostHog analytics (publishable client key — safe to expose)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Crisp chat (public website id)
NEXT_PUBLIC_CRISP_WEBSITE_ID=
