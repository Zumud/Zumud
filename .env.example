# Zumud backend environment — copy to `.env` and fill in.
# NEVER commit the real .env (it is gitignored).

# --- Runtime ---
ENVIRONMENT=development            # "production" on the server
FRONTEND_URL=http://localhost:3000

# --- OpenAI (required for generation) ---
OPEN_AI_KEY=

# --- Auth (Supabase Auth / GoTrue) ---
# Tokens are now issued by Supabase Auth and verified by the backend. For
# projects using the legacy symmetric (HS256) JWT secret, set it here
# (Dashboard -> Settings -> API -> JWT Settings). For projects on asymmetric
# signing keys (ES256/RS256), leave it unset; tokens are verified against the
# project JWKS derived from SUPABASE_URL.
SUPABASE_JWT_SECRET=

# Legacy/transitional: only used to keep pre-migration app-issued sessions valid
# during the cutover window (see backend/api/auth.py). Safe to drop afterwards.
SECRET_KEY=                        # generate: python -c "import secrets;print(secrets.token_hex(64))"
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# --- Supabase (Database is required; API keys needed for storage) ---
# DATABASE_URL: Dashboard -> Settings -> Database -> Connection string (URI)
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
SUPABASE_URL=https://<project-ref>.supabase.co
# New-style keys (Dashboard -> Settings -> API Keys). Legacy anon/service_role also accepted.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# --- LaTeX compiler (defaults to a sibling container on loopback) ---
# LATEX_COMPILER_BASE_URL=http://127.0.0.1:2700

# --- CORS (production: comma-separated allowed origins) ---
# CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# --- Sentry (optional error monitoring) ---
# SENTRY_DSN=

# --- Stripe (optional; billing is disabled unless these are set) ---
# STRIPE_SECRET_KEY=
# STRIPE_RESUME_PRICE_ID=
# STRIPE_COVERLETTER_PRICE_ID=
# STRIPE_QA_PRICE_ID=
# STRIPE_RESUME_EDIT_PRICE_ID=
# STRIPE_COVERLETTER_EDIT_PRICE_ID=
# STRIPE_QA_EDIT_PRICE_ID=
